# WebSocket port for ZapRemote iPhones to connect
PORT=8787

# ESPN game ID (same as Settings in the app)
ESPN_GAME_ID=401547417

# Broadcast channel label in events
CHANNEL=ESPN

# HLS playlist URL with SCTE-35 cue tags — real ad detection
# Example: a linear stream m3u8 that includes #EXT-X-CUE-OUT / SCTE35 markers
# HLS_URL=https://example.com/live/game.m3u8

# How far back to suggest rewinding when an ad is detected
SUGGESTED_REWIND_SECONDS=120

# Poll intervals (ms)
ESPN_POLL_MS=3000
HLS_POLL_MS=2000

# When HLS_URL is unset, fire lower-confidence ad_start on ESPN timeouts (1 = on, 0 = off)
ESPN_STOPPAGE_FALLBACK=1
